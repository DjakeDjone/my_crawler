# Global Port Configuration
# This file contains all port settings for the crawler project
# Copy this file to .env and adjust the values as needed

# API Server (Rust - api service)
API_HOST=127.0.0.1
API_PORT=8000

# Spider/Crawler Server (Rust - spider service)
SPIDER_HOST=127.0.0.1
SPIDER_PORT=8001

# Crawler Settings
CRAWLER_PRODUCT_TOKEN=MySearchBot
CRAWLER_USER_AGENT=MySearchBot/1.0 (+https://example.com/bot; contact@example.com)
ALLOWED_ORIGINS=http://localhost:3000

# Local non-Compose development
QDRANT_URL=http://localhost:6334
TEI_URL=http://localhost:8080
